FROM rust:alpine AS builder

RUN apk add --no-cache musl-dev

WORKDIR /build

# Copy only the crates needed for agentd
COPY crates/agentd crates/agentd
COPY crates/protocol crates/protocol
COPY Cargo.toml Cargo.toml

RUN cd crates/agentd && cargo build --release

FROM scratch
COPY --from=builder /build/crates/agentd/target/release/agentd /agentd
